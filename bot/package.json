services:
  lavalink:
    image: lavalink/lavalink:4
    # ... باقي الإعدادات
    networks:
      - bot-network

  music-bot:
    build:
      context: .
      dockerfile: bot/Dockerfile
    depends_on:
      - lavalink
    networks:
      - bot-network

networks:
  bot-network:
    driver: bridge
